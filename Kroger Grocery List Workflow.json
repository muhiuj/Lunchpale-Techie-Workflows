      "id": "7dc14e14-25b2-4dee-8ba9-9d1040c08a6e",
      "name": "Search Products",
      "credentials": {}
    },
    {
      "parameters": {
        "jsCode": "// Get all items from Search Products (API responses)\nconst allInputs = $input.all();\n\n// Get all items from Split Search Terms (store/search info)\nconst splitTermsItems = $('Split Search Terms').all();\n\nconst timestamp = new Date().toISOString();\nlet allRows = [];\n\n// Process each search result, pairing with corresponding store info\nfor (let i = 0; i < allInputs.length; i++) {\n  const apiResponse = allInputs[i].json;\n  const searchInfo = splitTermsItems[i].json;\n  \n  const products = apiResponse.data || [];\n  const searchTerm = searchInfo.searchTerm || 'Unknown';\n  const storeName = searchInfo.storeName || 'Unknown';\n  const storeAddress = searchInfo.storeAddress || 'Unknown';\n  \n  const rows = products.map(product => {\n    // Get the first item from items array\n    const items = product.items || [];\n    const item = items[0] || {};\n    \n    // Extract price - handle nested structure carefully\n    const regularPrice = item.price?.regular ?? null;\n    const promoPrice = item.price?.promo ?? null;\n    const stockLevel = item.inventory?.stockLevel ?? 'Unknown';\n    \n    return {\n      json: {\n        timestamp: timestamp,\n        storeName: `${storeName} - ${storeAddress}`,\n        searchTerm: searchTerm,\n        productName: product.description || '',\n        brand: product.brand || '',\n        size: item.size || '',\n        regularPrice: regularPrice,\n        promoPrice: promoPrice,\n        stockLevel: stockLevel,\n        productId: product.productId || ''\n      }\n    };\n  });\n  \n  allRows = allRows.concat(rows);\n}\n\nreturn allRows;"
      },
