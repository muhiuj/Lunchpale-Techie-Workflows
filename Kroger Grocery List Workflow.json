      "name": "Get Stores",
      "credentials": {}
    },
    {
      "parameters": {
        "jsCode": "const stores = $input.first().json.data;\n\n// Filter out fulfillment centers (they have \"FC\" in locationId)\nconst retailStores = stores.filter(store => \n  !store.locationId.includes('FC')\n);\n\n// Extract what we need including full address\nconst storeList = retailStores.map(store => ({\n  locationId: store.locationId,\n  name: store.name,\n  address: `${store.address.addressLine1}, ${store.address.city}, ${store.address.state} ${store.address.zipCode}`\n}));\n\nreturn [{\n  json: {\n    stores: storeList,\n    primaryStoreId: storeList[0].locationId,\n    primaryStoreName: storeList[0].name,\n    primaryStoreAddress: storeList[0].address\n  }\n}];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        832,
        0
      ],
      "id": "4367062b-a22e-499b-9c2a-a7d4010809d0",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst previousData = items[0].json;\n\nconst searchTerms = [\"milk\", \"eggs\", \"bread\", \"chicken breast\", \"bananas\"];\nconst primaryStoreId = previousData.primaryStoreId;\nconst primaryStoreName = previousData.primaryStoreName;\nconst primaryStoreAddress = previousData.primaryStoreAddress;\n\n// Create one item per search term, carrying store info forward\nreturn searchTerms.map(term => ({\n  json: {\n    searchTerm: term,\n    locationId: primaryStoreId,\n    storeName: primaryStoreName,\n    storeAddress: primaryStoreAddress\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
