    {
      "parameters": {
        "jsCode": "// Get raw CSV text from the HTTP request\nconst rawCSV = $input.first().json.data || $input.first().json;\nlet csvText = typeof rawCSV === 'string' ? rawCSV : JSON.stringify(rawCSV);\n\n// Parse CSV rows into subscriber objects\nconst lines = csvText.trim().split('\\n');\nconst headers = lines[0].split(',').map(h => h.trim().replace(/\\\"/g, ''));\n\nconst subscribers = [];\nfor (let i = 1; i < lines.length; i++) {\n  const values = lines[i].split(',').map(v => v.trim().replace(/\\\"/g, ''));\n  if (values.length >= 3 && values[2]) {\n    subscribers.push({\n      firstName: values[0] || '',\n      lastName: values[1] || '',\n      email: values[2] || '',\n      zone: values[3] || ''\n    });\n  }\n}\n\n// Get spike data from Parse All Zone Prices node\nconst spikeData = $('Parse All Zone Prices').first().json;\nconst spikes = spikeData.spikes;\n\n// For each spike zone, find matching subscribers and build alerts\nconst alerts = [];\n\nfor (const spike of spikes) {\n  const zoneSubscribers = subscribers.filter(sub => sub.zone === spike.zone);\n\n  for (const sub of zoneSubscribers) {\n    const message = `Hi ${sub.firstName},\\n\\n⚡ TEXAS ENERGY PRICE SPIKE ALERT ⚡\\n\\nCurrent wholesale price: $${spike.pricePerMWh}/MWh ($${spike.pricePerKWh}/kWh)\\nThat's ${spike.multiplier}x the normal rate!\\n\\nZone: ${spike.zone}\\nTime: ${spike.readableTime}\\n\\n💡 TIP: Avoid running your AC, dishwasher, or dryer right now. Wait 1-2 hours for prices to drop.\\n\\nThis alert is from Lunchpale Techie Workflows.\\n\\nFollow along:\\nInstagram: https://www.instagram.com/lunchpaletechie\\nYouTube: https://www.youtube.com/@muhiuj`;\n\n    alerts.push({\n      json: {\n        email: sub.email,\n        firstName: sub.firstName,\n        zone: spike.zone,\n        subject: `⚡ Energy Spike: ${spike.multiplier}x normal in ${spike.zone}`,\n        alertMessage: message\n      }\n    });\n  }\n}\n\n// If no subscribers match spiking zones, return empty so email node doesn't run\nif (alerts.length === 0) {\n  return [];\n}\n\nreturn alerts;"
