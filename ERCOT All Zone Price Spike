    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst data = response.data;\n\n// Filter for only \"LZ\" type records (skip \"LZEW\" duplicates)\nconst lzRecords = data.filter(row => row[4] === 'LZ');\n\n// The four ERCOT load zones we monitor\nconst zones = ['LZ_NORTH', 'LZ_HOUSTON', 'LZ_SOUTH', 'LZ_WEST'];\nconst thresholdMWh = 100;\nconst spikes = [];\n\nfor (const zoneName of zones) {\n  const zoneRecords = lzRecords.filter(row => row[3] === zoneName);\n  if (zoneRecords.length === 0) continue;\n\n  // Get the most recent record for this zone\n  const latest = zoneRecords[zoneRecords.length - 1];\n  const pricePerMWh = parseFloat(latest[5]);\n\n  if (pricePerMWh > thresholdMWh) {\n    spikes.push({\n      deliveryDate: latest[0],\n      deliveryHour: latest[1],\n      deliveryInterval: latest[2],\n      zone: latest[3],\n      pricePerMWh: pricePerMWh.toFixed(2),\n      pricePerKWh: (pricePerMWh / 1000).toFixed(4),\n      multiplier: (pricePerMWh / 25).toFixed(1),\n      readableTime: `${latest[0]} Hour ${latest[1]}, Interval ${latest[2]}`\n    });\n  }\n}\n\nreturn [{\n  json: {\n    hasSpikes: spikes.length > 0,\n    spikeCount: spikes.length,\n    spikes: spikes,\n    thresholdMWh: thresholdMWh,\n    timestamp: new Date().toISOString()\n  }\n}];"
